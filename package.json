{
  "name": "@datavac/ui-kit",
  "version": "1.6.1",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "style": "dist/index.css",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/index.css"
  },
  "scripts": {
    "theme:generate": "node scripts/generate-theme-css.mjs",
    "icons:generate": "node scripts/generate-icons.mjs",
    "build": "tsc -b && vite build && tsc --project tsconfig.declaration.json",
    "dev": "vite build --watch",
    "lint": "eslint ./src",
    "format": "prettier ./src --write",
    "test": "vitest run --project unit --passWithNoTests",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "test:storybook": "vitest run --project storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "git config core.hooksPath .git-hooks || echo 'Not in a git repo'",
    "chromatic": "npx chromatic"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "npm run lint --",
      "vitest run --passWithNoTests"
    ],
    "src/**/*": "npm run format -- --write"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "tailwind-merge": "3.5.0",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.1.2",
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@eslint/js": "10.0.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@storybook/addon-a11y": "10.3.6",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/addon-themes": "10.3.6",
    "@storybook/addon-vitest": "10.3.6",
    "@storybook/react": "10.3.6",
    "@storybook/react-vite": "10.3.6",
    "@tailwindcss/vite": "4.2.4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser": "4.1.5",
    "@vitest/browser-playwright": "4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.2",
    "playwright": "1.59.1",
    "prettier": "3.8.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "semantic-release": "25.0.3",
    "storybook": "10.3.6",
    "tailwindcss": "4.2.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.10",
    "vite-plugin-dts": "4.5.4",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.5"
  }
}
